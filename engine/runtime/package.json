{
  "name": "@pixelated/engine-runtime",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run check:source && npm run build && node --check dist/server.js && find dist/src -name '*.js' -exec node --check {} \\;",
    "check:source": "test -z \"$(find src -name '*.js' -print -quit)\"",
    "smoke:native": "node scripts/smokeNativeRuntime.mjs",
    "test": "npm run build && node --test dist/src/**/*.test.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
