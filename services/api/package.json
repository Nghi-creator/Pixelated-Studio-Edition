{
  "name": "@pixelated/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check:access-log-schema": "tsx scripts/stagingSmoke.ts --access-log-schema-only",
    "check:submission-cleanup-policy": "tsx scripts/stagingSmoke.ts --submission-cleanup-policy-only",
    "lint": "eslint .",
    "predeploy:hosted": "npm run check:access-log-schema && npm run check:submission-cleanup-policy && npm run typecheck && npm run lint && npm run build",
    "smoke:staging": "tsx scripts/stagingSmoke.ts",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@supabase/supabase-js": "^2.100.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.39.1",
    "globals": "^15.14.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
