{
  "name": "pixelated-desktop",
  "version": "1.0.0",
  "description": "Desktop companion for Pixelated Studio local and LAN game streaming.",
  "author": "Pixelated Studio",
  "main": "dist/main.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { force: true, recursive: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "start": "npm run build && electron .",
    "prepare:web": "npm run build && npm --prefix ../web run build && node dist/scripts/prepareWebDist.js",
    "smoke:release": "npm run build && node dist/scripts/releaseSmoke.js",
    "dist": "npm run prepare:web && electron-builder && npm run smoke:release",
    "dist:ci": "npm run prepare:web && electron-builder --publish never && npm run smoke:release"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "electron": "^29.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "build": {
    "appId": "com.pixelated.studio",
    "productName": "Pixelated Studio",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "package.json",
      "index.html",
      "dist/**",
      "!release/**",
      "!tests/**",
      "!dist/tests/**",
      "!dist/**/*.test.js",
      "!dist/scripts/**",
      "!dist/mac{,/**/*}",
      "!dist/mac-arm64{,/**/*}",
      "!dist/*.dmg",
      "!dist/*.zip",
      "!dist/*.blockmap",
      "!dist/builder-debug.yml",
      "!dist/builder-effective-config.yaml"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../engine/runtime",
        "to": "engine-runtime",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!dist/**",
          "!__pycache__/**",
          "!**/__pycache__/**",
          "!*.pyc",
          "!**/*.pyc"
        ]
      }
    ]
  }
}
