{
  "name": "pixelated-studio-edition",
  "private": true,
  "scripts": {
    "check:access-log-schema": "npm --prefix services/api run check:access-log-schema",
    "predeploy:hosted": "npm --prefix services/api run predeploy:hosted",
    "smoke:hosted-auth": "node scripts/hosted/hostedAuthSmoke.mjs",
    "smoke:hosted-pairing": "node scripts/hosted/hostedPairingSmoke.mjs",
    "smoke:lan": "node scripts/lan/multiplayerSmoke.mjs",
    "smoke:lan-summary": "node scripts/lan/summarizeSmokeArtifacts.mjs",
